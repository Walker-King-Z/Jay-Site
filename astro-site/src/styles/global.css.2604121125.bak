body {
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
  line-height: 1.7;
  margin: 0;
  color: #222;
}

.container {
  max-width: 760px;
  margin: 0 auto;
  padding: 2rem;
}

.site-header {
  border-bottom: 1px solid #eee;
  padding: 1rem 2rem;
}

.site-header a {
  text-decoration: none;
  color: inherit;
}

nav a {
  margin-right: 1rem;
}

.site-footer {
  border-top: 1px solid #eee;
  padding: 2rem;
  text-align: center;
  color: #777;
}
